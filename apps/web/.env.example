# App
VITE_API_URL=http://localhost:3000
VITE_APP_ENV=development

# ── Auth mode ─────────────────────────────────────────────────────────────────
# 'legacy' (default): in-browser MSAL SSO + Bearer tokens.
# 'bff': same-origin Backend-for-Frontend — login/session handled server-side via
# /bff/* (edge-proxied to the API), browser holds only the session cookie.
# VITE_AUTH_MODE=legacy

# ── Dev login (non-production only) ─────────────────────────────────────
# Shows a passwordless seeded-account form so QA can sign in without Entra. Works
# in both auth modes; set to true ONLY on local + non-prod (QA) environments. The
# API also hard-blocks dev-login when NODE_ENV=production, so prod is safe either way.
# VITE_DEV_LOGIN=true

# ── SSO / Microsoft Entra ID (optional — leave empty to disable SSO) ──────────
# When both are set, the login page shows a Microsoft button and the router
# redirects unauthenticated users directly to Microsoft instead of the login page.
# VITE_ENTRA_TENANT_ID=your-azure-tenant-id
# VITE_ENTRA_CLIENT_ID=your-azure-app-client-id
