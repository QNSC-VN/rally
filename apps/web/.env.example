# App
VITE_API_URL=http://localhost:3000
VITE_APP_ENV=development

# ── SSO / Microsoft Entra ID (optional — leave empty to disable SSO) ──────────
# When both are set, the login page shows a Microsoft button and the router
# redirects unauthenticated users directly to Microsoft instead of the login page.
# VITE_ENTRA_TENANT_ID=your-azure-tenant-id
# VITE_ENTRA_CLIENT_ID=your-azure-app-client-id
