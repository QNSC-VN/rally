# App
VITE_API_URL=http://localhost:3000
VITE_APP_ENV=development

# ── Dev login (non-production only) ─────────────────────────────────────
# Shows a passwordless seeded-account form so QA can sign in without Entra. Set
# to true ONLY on local + non-prod (QA) environments. The API also hard-blocks
# dev-login when NODE_ENV=production, so prod is safe either way.
# VITE_DEV_LOGIN=true
