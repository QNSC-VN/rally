# ── App ──────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3000
HOST=0.0.0.0
CORS_ORIGINS=http://localhost:5173
# Set to 'true' in local dev to bypass all rate limiting. Never set in prod.
DISABLE_RATE_LIMIT=false

# ── Database ─────────────────────────────────────────────────────
# Full DSN including pool limits
DATABASE_URL=postgresql://rally_app:changeme@localhost:5432/rally_dev?sslmode=disable
DATABASE_POOL_MIN=2
DATABASE_POOL_MAX=20

# Separate privileged URL for migrations (bypasses RLS)
DATABASE_MIGRATION_URL=postgresql://rally_migrate:changeme@localhost:5432/rally_dev?sslmode=disable

# ── Redis / Valkey ────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379
REDIS_KEY_PREFIX=rally:

# ── Auth / JWT ────────────────────────────────────────────────────
# EC P-256 asymmetric keypair for ES256 signing. Generate:
#   openssl ecparam -name prime256v1 -genkey -noout | openssl pkcs8 -topk8 -nocrypt -out private.pem
#   openssl ec -in private.pem -pubout -out public.pem
# Base64 for ECS secrets:  base64 -w0 < private.pem
JWT_PRIVATE_KEY=
JWT_PUBLIC_KEY=
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=30d
JWT_ISSUER=rally-api
JWT_AUDIENCE=rally-web

# CSRF secret (min 32 chars)
CSRF_SECRET=change-me-to-a-random-32char-secret

# ── AWS ───────────────────────────────────────────────────────────
AWS_REGION=ap-southeast-1
AWS_ACCOUNT_ID=000000000000

# LocalStack (dev) — full local AWS, no real account needed.
# docker compose -f docker-compose.dev.yml up -d  ← starts LocalStack and
# automatically creates all queues, topics, and the S3 bucket via the
# init hook (scripts/localstack/init.sh).
# Production resources live in the rally-infra repo (Terraform).
AWS_ENDPOINT_URL=http://localhost:4566
AWS_ACCESS_KEY_ID=test
AWS_SECRET_ACCESS_KEY=test

# SNS / SQS — LocalStack ARNs/URLs are deterministic (account = 000000000000)
SNS_TOPIC_ARN=arn:aws:sns:ap-southeast-1:000000000000:rally-domain-events
SQS_NOTIFICATIONS_URL=http://localhost:4566/000000000000/rally-notifications
SQS_AUDIT_URL=http://localhost:4566/000000000000/rally-audit
SQS_REPORTING_URL=http://localhost:4566/000000000000/rally-reporting
SQS_SEARCH_URL=

# S3
S3_ATTACHMENTS_BUCKET=rally-dev-attachments

# ── Observability ─────────────────────────────────────────────────
OTEL_ENABLED=false
OTEL_SERVICE_NAME=rally-api
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318

LOG_LEVEL=debug
LOG_PRETTY=true
LOG_SQL=false
LOG_HTTP_BODIES=false
LOG_DEV_EMAIL_CONTENT=false

# ── Resilience ────────────────────────────────────────────────────
RESILIENCE_ENABLED=true

# ── SSO / Microsoft Entra ID (optional — leave empty to disable SSO) ──────────
# When set, the API validates Entra ID tokens via JWKS and provisions users JIT.
# ENTRA_TENANT_ID=your-azure-tenant-id
# ENTRA_CLIENT_ID=your-azure-app-client-id
# Comma-separated JIT allow-list; only these email domains can self-provision.
# SSO_ALLOWED_EMAIL_DOMAINS=qnsc.vn

# ── Platform admin (SSO auto-elevation) ─────────────────────────────────────
# Auth is SSO-only (passwordless). The first admin is NOT a seeded account —
# put their Entra email here and they are auto-granted workspace_admin on first
# SSO login. Comma-separated.
PLATFORM_ADMIN_EMAILS=

# ── Tenant bootstrap (workspace + SSO connection) ───────────────────────────
# The primary workspace + Entra SSO connection are created on every deploy (all
# envs) so real users can JIT-provision. These override the defaults.
# BOOTSTRAP_WORKSPACE_NAME=ACME Corp
# BOOTSTRAP_WORKSPACE_SLUG=main

# Demo fixtures (demo users, sample projects/work items) — dev/staging/E2E only.
# Never set in production; prod runs only the prod-safe roles + tenant bootstrap.
SEED_ON_DEPLOY=true

# ── Email (─────────────────────────────────────────────
EMAIL_PROVIDER=ses
