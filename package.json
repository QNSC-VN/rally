{
  "name": "rally",
  "version": "0.2.2",
  "private": true,
  "license": "UNLICENSED",
  "engines": {
    "node": ">=22.0.0",
    "pnpm": ">=9.0.0"
  },
  "pnpm": {
    "overrides": {
      "fastify": "5.10.0",
      "esbuild@<0.25.0": ">=0.25.0"
    }
  },
  "scripts": {
    "build:api": "nest build api",
    "build:worker": "nest build worker",
    "build:migrator": "tsc --project tsconfig.migrator.json",
    "build": "pnpm build:api && pnpm build:worker",
    "build:web": "pnpm --filter rally-web build",
    "dev:web": "pnpm --filter rally-web dev",
    "format": "prettier --write \"apps/api/**/*.ts\" \"apps/worker/**/*.ts\" \"libs/**/*.ts\" \"db/**/*.ts\"",
    "start:dev": "nest start api --watch",
    "start:dev:worker": "nest start worker --watch",
    "start:debug": "nest start api --debug --watch",
    "start:prod": "node dist/apps/api/apps/api/src/main.js",
    "start:prod:worker": "node dist/apps/worker/apps/worker/src/main.js",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "lint": "eslint \"{apps/api,apps/worker,libs,db}/**/*.ts\"",
    "lint:fix": "eslint \"{apps/api,apps/worker,libs,db}/**/*.ts\" --fix",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:cov": "vitest run --coverage",
    "test:e2e": "vitest run --config test/vitest.e2e.config.ts",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "tsx db/migrate.ts",
    "db:seed": "tsx db/seeds/seed.ts",
    "db:studio": "drizzle-kit studio",
    "prepare": "husky"
  },
  "lint-staged": {
    "*.ts": [
      "eslint --fix --max-warnings=0",
      "prettier --write"
    ]
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1079.0",
    "@aws-sdk/client-secrets-manager": "^3.1079.0",
    "@aws-sdk/client-ses": "^3.1079.0",
    "@aws-sdk/client-sns": "^3.1079.0",
    "@aws-sdk/client-sqs": "^3.1079.0",
    "@aws-sdk/s3-request-presigner": "^3.1079.0",
    "@fastify/compress": "^9.0.0",
    "@fastify/cookie": "^11.0.0",
    "@fastify/csrf-protection": "^8.0.0",
    "@fastify/helmet": "^13.0.2",
    "@fastify/multipart": "^10.0.0",
    "@fastify/static": "^9.1.3",
    "@nestjs/common": "^11.0.0",
    "@nestjs/config": "^4.0.0",
    "@nestjs/core": "^11.0.0",
    "@nestjs/jwt": "^11.0.0",
    "@nestjs/passport": "^11.0.0",
    "@nestjs/platform-fastify": "^11.0.0",
    "@nestjs/schedule": "^6.1.3",
    "@nestjs/swagger": "^11.4.5",
    "@nestjs/terminus": "^11.0.0",
    "@opentelemetry/api": "^1.9.1",
    "@opentelemetry/auto-instrumentations-node": "^0.78.0",
    "@opentelemetry/exporter-metrics-otlp-http": "^0.220.0",
    "@opentelemetry/exporter-trace-otlp-http": "^0.220.0",
    "@opentelemetry/resources": "^2.9.0",
    "@opentelemetry/sdk-metrics": "^2.9.0",
    "@opentelemetry/sdk-node": "^0.220.0",
    "@opentelemetry/sdk-trace-base": "^2.9.0",
    "@opentelemetry/semantic-conventions": "^1.41.1",
    "@qnsc-vn/identity": "^5.3.0",
    "@qnsc-vn/platform-cache": "^2.1.0",
    "@qnsc-vn/platform-http": "^3.0.0",
    "argon2": "^0.44.0",
    "cockatiel": "^4.0.0",
    "drizzle-orm": "^0.45.0",
    "drizzle-zod": "^0.8.0",
    "fastify": "^5.10.0",
    "ioredis": "^5.11.1",
    "jose": "^6.2.3",
    "nestjs-pino": "^4.6.1",
    "nestjs-zod": "^5.4.0",
    "passport": "^0.7.0",
    "passport-jwt": "^4.0.1",
    "pg": "^8.22.0",
    "pino": "^10.3.1",
    "pino-http": "^11.0.0",
    "reflect-metadata": "^0.2.2",
    "resend": "^6.17.1",
    "rxjs": "^7.8.2",
    "uuidv7": "^1.2.1",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@commitlint/cli": "^21.2.0",
    "@commitlint/config-conventional": "^21.2.0",
    "@eslint/js": "^10.0.1",
    "@nestjs/cli": "^11.0.0",
    "@nestjs/schematics": "^11.0.0",
    "@nestjs/testing": "^11.0.0",
    "@swc/cli": "^0.8.1",
    "@swc/core": "^1.15.43",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^26.1.0",
    "@types/passport-jwt": "^4.0.1",
    "@types/pg": "^8.11.13",
    "@types/supertest": "^7.2.0",
    "@typescript-eslint/eslint-plugin": "^8.62.1",
    "@typescript-eslint/parser": "^8.62.1",
    "@vitest/coverage-v8": "^4.1.10",
    "drizzle-kit": "^0.31.10",
    "eslint": "^10.6.0",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.8",
    "pino-pretty": "^13.0.0",
    "prettier": "^3.9.4",
    "supertest": "^7.0.0",
    "testcontainers": "^12.0.4",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "tsx": "^4.23.0",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.62.1",
    "unplugin-swc": "^1.5.9",
    "vite-tsconfig-paths": "^6.1.1",
    "vitest": "^4.1.10"
  }
}
